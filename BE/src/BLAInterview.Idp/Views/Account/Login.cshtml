@model LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in — BLA Interview IDP</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 24rem; margin: 2rem auto; padding: 0 1rem; }
        label { display: block; margin-top: 1rem; font-weight: 600; }
        input { width: 100%; box-sizing: border-box; margin-top: 0.25rem; padding: 0.5rem; }
        button { margin-top: 1.25rem; padding: 0.5rem 1rem; width: 100%; cursor: pointer; }
        .field-validation-error { color: #b00020; font-size: 0.9rem; }
        .validation-summary-errors { color: #b00020; margin-bottom: 1rem; }
        .flash-success { color: #0d6d32; margin-bottom: 1rem; }
        .secondary { margin-top: 1rem; font-size: 0.95rem; }
        a { color: #0066cc; }
    </style>
</head>
<body>
    <h1>Sign in</h1>
    <p>Use the email and password you registered with.</p>
    @if (TempData["RegistrationSuccess"] is string registrationSuccess)
    {
        <p class="flash-success">@registrationSuccess</p>
    }
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
    <form asp-action="Login" method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <label asp-for="Email"></label>
        <input asp-for="Email" autocomplete="username" />
        <span asp-validation-for="Email" class="field-validation-error"></span>
        <label asp-for="Password"></label>
        <input asp-for="Password" autocomplete="current-password" />
        <span asp-validation-for="Password" class="field-validation-error"></span>
        <button type="submit">Sign in</button>
    </form>
    <p class="secondary"><a asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a></p>
</body>
</html>
