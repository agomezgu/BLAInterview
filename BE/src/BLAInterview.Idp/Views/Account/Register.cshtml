@model RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Create account — BLA Interview IDP</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 24rem; margin: 2rem auto; padding: 0 1rem; }
        label { display: block; margin-top: 1rem; font-weight: 600; }
        input { width: 100%; box-sizing: border-box; margin-top: 0.25rem; padding: 0.5rem; }
        button { margin-top: 1.25rem; padding: 0.5rem 1rem; width: 100%; cursor: pointer; }
        .field-validation-error { color: #b00020; font-size: 0.9rem; }
        .validation-summary-errors { color: #b00020; margin-bottom: 1rem; }
        .secondary { margin-top: 1rem; font-size: 0.95rem; }
        a { color: #0066cc; }
    </style>
</head>
<body>
    <h1>Create account</h1>
    <p>Register to sign in to BLA Interview with email and password.</p>
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
    <form asp-action="Register" method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <label asp-for="Name"></label>
        <input asp-for="Name" autocomplete="name" />
        <span asp-validation-for="Name" class="field-validation-error"></span>
        <label asp-for="Email"></label>
        <input asp-for="Email" autocomplete="email" />
        <span asp-validation-for="Email" class="field-validation-error"></span>
        <label asp-for="Password"></label>
        <input asp-for="Password" autocomplete="new-password" />
        <span asp-validation-for="Password" class="field-validation-error"></span>
        <label asp-for="ConfirmPassword"></label>
        <input asp-for="ConfirmPassword" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        <button type="submit">Create account</button>
    </form>
    <p class="secondary"><a asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">Already have an account? Sign in</a></p>
</body>
</html>
