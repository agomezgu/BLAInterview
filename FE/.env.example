# ---------------------------------------------------------------------------
# API — point to your BLAInterview (or other) Web API. In dev, use the Vite
# proxy (see vite.config.ts): set the base to /api so same-origin = no CORS.
# In production, use the public origin of the API, e.g. https://api.example.com
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=/api

# ---------------------------------------------------------------------------
# Mock: no real HTTP / IDP. Good for layout and UI before wiring a real IDP.
# Set to false to use OIDC and the real API.
# ---------------------------------------------------------------------------
VITE_MOCK_API=false

# ---------------------------------------------------------------------------
# OIDC / OAuth2 (public SPA, PKCE). Get authority, client id, and callback URLs
# from your identity provider. Scope must include your API resource scope, e.g.
# bla-interview-api, or the API will return 403.
# ---------------------------------------------------------------------------
# Local Duende host (see BE BLAInterview.Idp launchSettings https profile, port 7007):
VITE_OIDC_AUTHORITY=https://localhost:7007
VITE_OIDC_CLIENT_ID=bla-interview-spa
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
# Space-separated, include api audience + openid
VITE_OIDC_SCOPE=openid profile offline_access bla-interview-api

# ---------------------------------------------------------------------------
# Registration: prefer hosted (redirect). If the IDP has no public registration
# API from the browser, use hosted only.
# ---------------------------------------------------------------------------
VITE_USE_HOSTED_REGISTRATION=true
# Hosted sign-up page URL (Duende, Auth0, Keycloak, etc.):
# Local Duende IDP account page (see BE BLAInterview.Idp /Account/Register):
VITE_OIDC_REGISTRATION_URL=https://localhost:7007/Account/Register
# If hosted is false, point to a public register endpoint. Adjust the JSON body
# in RegisterPage.tsx to match the server contract.
VITE_REGISTRATION_API_URL=
